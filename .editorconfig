# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Default settings
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Python files
[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Shell scripts
[*.{sh,bash}]
indent_style = space
indent_size = 2

# PowerShell scripts
[*.ps1]
indent_style = space
indent_size = 4

# Makefile
[Makefile]
indent_style = tab

# TOML files
[*.toml]
indent_style = space
indent_size = 4

# INI files
[*.ini]
indent_style = space
indent_size = 4

# Dockerfile
[Dockerfile]
indent_style = space
indent_size = 2

# Configuration files
[.env.example]
indent_style = space
indent_size = 2
insert_final_newline = false
