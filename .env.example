# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_TITLE="TTS System API"
API_VERSION=v1

# Database
DATABASE_URL=sqlite:///./database/tts_sys.db
DATABASE_ECHO=false

# Storage
STORAGE_PATH=./storage
CACHE_ENABLED=true
CACHE_MAX_SIZE_MB=1024
CACHE_TTL_DAYS=30

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Edge TTS (Free, no key required)
EDGE_TTS_ENABLED=true

# Youdao TTS
YOUDAO_TTS_ENABLED=false
YOUDAO_APP_KEY=
YOUDAO_APP_SECRET=

# Azure Cognitive Services
AZURE_TTS_ENABLED=false
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# Google Cloud TTS
GOOGLE_TTS_ENABLED=false
GOOGLE_APPLICATION_CREDENTIALS=

# OpenAI TTS
OPENAI_TTS_ENABLED=false
OPENAI_API_KEY=
OPENAI_TTS_MODEL=tts-1

# Pyttsx3 (Local Offline TTS - Fallback)
PYTTSX3_ENABLED=true

# Fallback / Circuit Breaker Configuration
TTS_ENABLE_AUTO_FALLBACK=true
TTS_MAX_RETRIES=2
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_SECONDS=60
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]
CORS_ALLOW_CREDENTIALS=true
